#!/bin/bash
# Claude Code → tmux 状态栏 hook
# 用法: tmux-claude-status <EVENT_TYPE>
# stdin: Claude Code 传入的 JSON 数据

TOOL_ID="claude"
EVENT="$1"
INPUT=$(cat)

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "${SCRIPT_DIR}/lib-tmux-ai-status.sh"

# 解析 TMUX_PANE
resolve_tmux_pane

# 缓存 pane 可读位置信息
_pane_loc=""
if [ -n "$TMUX_PANE" ]; then
    _pane_loc=$(tmux display-message -pt "$TMUX_PANE" -p "#{session_name}:#{window_index}.#{pane_index}" 2>/dev/null)
fi

WATCHER_PID_FILE="/tmp/${TOOL_ID}-watcher-${TMUX_PANE//[^a-zA-Z0-9]/_}.pid"
PROTECT_FILE="/tmp/${TOOL_ID}-protect-${TMUX_PANE//[^a-zA-Z0-9]/_}"

# hooks 完整性校验：确保所有事件都已注册本插件的 hook
_check_hooks_integrity() {
    local settings_file="${CLAUDE_CONFIG_DIR:-$HOME/.claude}/settings.json"
    [ -f "$settings_file" ] || return 1
    local registered
    registered=$(jq '
        .hooks as $h |
        ["SessionStart","SessionEnd","UserPromptSubmit","PreToolUse","PostToolUse",
         "PostToolUseFailure","PermissionRequest","Notification","Stop","StopFailure"]
        | map(select([$h[.][]?.hooks[]?.command // empty] | any(contains("tmux-claude-status"))))
        | length
    ' "$settings_file" 2>/dev/null)
    [ "${registered:-0}" -ge 10 ]
}

case "$EVENT" in
  Notification)
    MSG=$(echo "$INPUT" | jq -r '.message // ""' 2>/dev/null)
    case "$MSG" in
      *"waiting for your input"*)
        STATUS="-"
        _ai_log "SET - msg=waiting_for_input"
        ;;
      *"denied"*|*"cancelled"*|*"canceled"*|*"rejected"*)
        STATUS="-"
        kill_watcher "$TOOL_ID"
        _ai_log "SET - msg=denied/cancelled"
        ;;
      *"permission"*|*"Permission"*)
        STATUS="!"
        kill_watcher "$TOOL_ID"
        start_status_watcher "$TOOL_ID" "!"
        _ai_log "SET ! msg=permission"
        ;;
      *)
        exit 0
        ;;
    esac
    ;;
  PermissionRequest)
    STATUS="!"
    _set_protection "$TOOL_ID"
    kill_watcher "$TOOL_ID"
    start_status_watcher "$TOOL_ID" "!"
    _ai_log "SET ! +watcher +protect"
    ;;
  PreToolUse)
    # 竞态保护：检查保护文件而非 tmux 状态（PermissionRequest 可能尚未写入 !）
    if [ -n "$TMUX_PANE" ] && _is_protected "$TOOL_ID"; then
      _ai_log "SKIP: protected=yes"
      exit 0
    fi
    TOOL=$(echo "$INPUT" | jq -r '.tool_name // ""' 2>/dev/null)
    if [ "$TOOL" = "AskUserQuestion" ]; then
        STATUS="?"
        kill_watcher "$TOOL_ID"
        start_status_watcher "$TOOL_ID" "?"
        _set_protection "$TOOL_ID"
        _ai_log "SET ? tool=$TOOL +watcher +protect"
    else
        STATUS=">"
        # 不 kill watcher：若 PermissionRequest 并发设置了 !，
        # watcher 会通过保护窗口重新断言
        _ai_log "SET > tool=$TOOL"
    fi
    ;;
  PostToolUse|PostToolUseFailure)
    # 竞态保护：检查保护文件而非 tmux 状态
    if [ -n "$TMUX_PANE" ] && _is_protected "$TOOL_ID"; then
      _ai_log "SKIP: protected=yes"
      exit 0
    fi
    STATUS=">"
    kill_watcher "$TOOL_ID"
    _ai_log "SET >"
    ;;
  UserPromptSubmit)
    STATUS=">"
    kill_watcher "$TOOL_ID"
    _ai_log "SET > (user submitted)"
    ;;
  Stop|StopFailure)
    kill_watcher "$TOOL_ID"
    # 检查当前状态：! 表示权限被拒绝后结束，回到 - 空闲；其余情况显示 ✓ 完成
    if [ -n "$TMUX_PANE" ]; then
        cur_status=$(tmux display-message -pt "$TMUX_PANE" -p "#{@claude_pane_status}" 2>/dev/null)
        if [ "$cur_status" = "!" ]; then
            STATUS="-"
        else
            STATUS="✓"
        fi
        _ai_log "SET $STATUS (cur was $cur_status)"
    else
        STATUS="✓"
        _ai_log "SET ✓ (no TMUX_PANE)"
    fi
    # fallback：如果 TMUX_PANE 未解析，清除所有残留的处理中状态
    if [ -n "$TMUX" ] && [ -z "$TMUX_PANE" ]; then
        while IFS='|' read -r pane_id pane_status; do
            case "$pane_status" in
                ">") tmux set-option -pt "$pane_id" @claude_pane_status "✓" 2>/dev/null ;;
                "!") tmux set-option -pt "$pane_id" @claude_pane_status "-" 2>/dev/null ;;
            esac
        done < <(tmux list-panes -a -F "#{pane_id}|#{@claude_pane_status}" 2>/dev/null)
        build_all_status
        tmux set-option -g @ai_all_status "$ALL" 2>/dev/null
    fi
    ;;
  SessionStart)
    STATUS="-"
    # hooks 完整性校验：检测到缺失时自动修复并提示
    if ! _check_hooks_integrity; then
        "${SCRIPT_DIR}/install-claude-hooks.sh" >/dev/null 2>&1
        tmux display-message "⚠ Claude hooks 已自动修复（检测到缺失）" 2>/dev/null || true
        _ai_log "SET - hooks_fixed=yes"
    else
        _ai_log "SET - hooks_ok=yes"
    fi
    ;;
  SessionEnd)
    STATUS=""
    kill_watcher "$TOOL_ID"
    _ai_log "SET (empty) session ended"
    ;;
  _refresh)
    # 由 tmux session-closed / client-detached hook 触发，重建聚合状态
    build_all_status
    tmux set-option -g @ai_all_status "$ALL" 2>/dev/null || true
    _ai_log "REFRESH"
    exit 0
    ;;
  *)
    exit 0
    ;;
esac

# 写入 tmux 全局变量
tmux set-option -g @claude_status "$STATUS" 2>/dev/null || true

# 写入 pane 用户变量（当在 tmux pane 内运行时，每个 pane 独立显示）
if [ -n "$TMUX" ] && [ -n "$TMUX_PANE" ]; then
    tmux set-option -pt "$TMUX_PANE" @claude_pane_status "$STATUS" 2>/dev/null || true

    # 重建聚合状态：扫描所有 pane，收集非空状态写入全局变量供状态栏使用
    build_all_status
    tmux set-option -g @ai_all_status "$ALL" 2>/dev/null || true
    tmux refresh-client -S 2>/dev/null || true
    _ai_log "WRITE status=$STATUS"
fi
