#!/bin/bash
# Claude Code → tmux 状态栏 hook
# 用法: tmux-status.sh <EVENT_TYPE>
# stdin: Claude Code 传入的 JSON 数据

EVENT="$1"
INPUT=$(cat)

# Claude Code 的 hook 子进程不继承 $TMUX_PANE，通过进程树向上查找所属 pane
if [ -n "$TMUX" ] && [ -z "$TMUX_PANE" ]; then
    check_pid=$$
    while [ "${check_pid:-0}" -gt 1 ]; do
        found=$(tmux list-panes -a -F "#{pane_id} #{pane_pid}" 2>/dev/null \
                | awk -v pid="$check_pid" '$2==pid{print $1; exit}')
        if [ -n "$found" ]; then TMUX_PANE="$found"; break; fi
        check_pid=$(ps -o ppid= -p "$check_pid" 2>/dev/null | tr -d '[:space:]')
    done
fi

WATCHER_PID_FILE="/tmp/claude-watcher-${TMUX_PANE//[^a-zA-Z0-9]/_}.pid"

# 启动后台 watcher：监控 pane title 停止变化 → 判断为空闲（捕获 ESC 中断）
start_watcher() {
    if [ -z "$TMUX_PANE" ]; then return; fi
    (
        prev_title=""
        stable_count=0
        while true; do
            sleep 1
            current_title=$(tmux display -pt "$TMUX_PANE" "#{pane_title}" 2>/dev/null)
            if [ "$current_title" = "$prev_title" ]; then
                stable_count=$((stable_count + 1))
                # title 连续 3 秒不变 → Claude 已空闲
                if [ "$stable_count" -ge 3 ]; then
                    tmux set-option -pt "$TMUX_PANE" @claude_pane_status "-" 2>/dev/null
                    ALL=""
                    current_session=""
                    while IFS='|' read -r session_name win_idx pane_idx pane_status; do
                        [ -n "$pane_status" ] || continue
                        if [ "$session_name" != "$current_session" ]; then
                            ALL="${ALL:+$ALL  }[${session_name}] ${win_idx}.${pane_idx}:${pane_status}"
                            current_session="$session_name"
                        else
                            ALL="${ALL} ${win_idx}.${pane_idx}:${pane_status}"
                        fi
                    done < <(tmux list-panes -a -F "#{session_name}|#{window_index}|#{pane_index}|#{@claude_pane_status}" 2>/dev/null)
                    tmux set-option -g @claude_all_status "$ALL" 2>/dev/null
                    rm -f "$WATCHER_PID_FILE"
                    exit 0
                fi
            else
                stable_count=0
                prev_title="$current_title"
            fi
        done
    ) &
    echo $! > "$WATCHER_PID_FILE"
    disown
}

# 杀掉当前 watcher
kill_watcher() {
    if [ -z "$TMUX_PANE" ]; then return; fi
    if [ -f "$WATCHER_PID_FILE" ]; then
        kill "$(cat "$WATCHER_PID_FILE")" 2>/dev/null
        rm -f "$WATCHER_PID_FILE"
    fi
}

case "$EVENT" in
  Notification)
    MSG=$(echo "$INPUT" | jq -r '.message // ""' 2>/dev/null)
    case "$MSG" in
      *"waiting for your input"*)
        STATUS="?"
        ;;
      *"permission"*|*"Permission"*)
        STATUS="!"
        ;;
      *)
        STATUS="?"
        ;;
    esac
    ;;
  PermissionRequest)
    STATUS="!"
    ;;
  PreToolUse)
    STATUS="..."
    kill_watcher
    ;;
  PostToolUse|PostToolUseFailure)
    STATUS="..."
    kill_watcher
    start_watcher
    ;;
  UserPromptSubmit)
    STATUS="..."
    kill_watcher
    start_watcher
    ;;
  Stop|StopFailure)
    STATUS="✓"
    kill_watcher
    # fallback：如果 TMUX_PANE 未解析，清除所有残留的处理中状态
    if [ -n "$TMUX" ] && [ -z "$TMUX_PANE" ]; then
        while IFS='|' read -r pane_id pane_status; do
            [ "$pane_status" = "..." ] && tmux set-option -pt "$pane_id" @claude_pane_status "✓" 2>/dev/null
        done < <(tmux list-panes -a -F "#{pane_id}|#{@claude_pane_status}" 2>/dev/null)
    fi
    ;;
  SessionStart)
    STATUS="-"
    ;;
  SessionEnd)
    STATUS=""
    kill_watcher
    ;;
  *)
    exit 0
    ;;
esac

# 写入 tmux 全局变量（status-left/right 通过 #{@claude_status} 读取）
tmux set-option -g @claude_status "$STATUS" 2>/dev/null || true

# 写入 pane 用户变量（当在 tmux pane 内运行时，每个 pane 独立显示）
if [ -n "$TMUX" ] && [ -n "$TMUX_PANE" ]; then
    tmux set-option -pt "$TMUX_PANE" @claude_pane_status "$STATUS" 2>/dev/null || true

    # 重建聚合状态：扫描所有 pane，收集非空状态写入全局变量供状态栏使用
    ALL=""
    current_session=""
    while IFS='|' read -r session_name win_idx pane_idx pane_status; do
        [ -n "$pane_status" ] || continue
        if [ "$session_name" != "$current_session" ]; then
            ALL="${ALL:+$ALL  }[${session_name}] ${win_idx}.${pane_idx}:${pane_status}"
            current_session="$session_name"
        else
            ALL="${ALL} ${win_idx}.${pane_idx}:${pane_status}"
        fi
    done < <(tmux list-panes -a -F "#{session_name}|#{window_index}|#{pane_index}|#{@claude_pane_status}" 2>/dev/null)
    tmux set-option -g @claude_all_status "$ALL" 2>/dev/null || true
fi
